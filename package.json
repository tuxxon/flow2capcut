{
  "name": "flow2capcut-desktop",
  "version": "0.1.0",
  "description": "AutoCraft Studio - Automate AI video creation from Google Flow to CapCut projects",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:prod": "vite --mode production",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "pack": "vite build && electron-builder --dir",
    "dist": "vite build --mode production && electron-builder",
    "dist:mac": "vite build --mode production && electron-builder --mac",
    "dist:win": "vite build --mode production && electron-builder --win",
    "dist:test": "vite build --mode development && electron-builder",
    "dist:test:mac": "vite build --mode development && electron-builder --mac",
    "dist:test:win": "vite build --mode development && electron-builder --win",
    "dist:win:nsis": "vite build --mode production && electron-builder --win nsis",
    "dist:win:appx": "vite build --mode production && electron-builder --win appx",
    "dist:win:all": "vite build --mode production && electron-builder --win",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "author": "Touchizen",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "dotenv": "^17.3.1",
    "firebase": "^12.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^34.1.1",
    "electron-builder": "^26.7.0",
    "jsdom": "^28.1.0",
    "vite": "^6.1.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.touchizen.flow2capcut",
    "productName": "AutoCraft Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "!assets/icon.iconset"
    ],
    "afterSign": "scripts/notarize.cjs",
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.video",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "zip",
        "appx"
      ]
    },
    "appx": {
      "identityName": "6129CF9F.AutoCraftStudio",
      "publisher": "CN=5939ADED-0FF9-4D26-A5D6-928AE9B2B6BC",
      "publisherDisplayName": "Touchizen",
      "languages": [
        "en-US",
        "ko-KR"
      ],
      "applicationId": "AutoCraftStudio",
      "displayName": "AutoCraft Studio"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
